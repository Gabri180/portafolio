---
const projects = [
  {
    title: "Negocio de Minecraft",
    period: "2021 – 2023",
    tags: ["Minecraft", "BuiltByBit", "Gestión de servidores"],
    story: "Empezó como un hobby y terminó generando más de 3.000€. Vendí builds personalizados en BuiltByBit, gestioné servers para otros y llegué a tener una mini-tienda. No tenía ni idea de programar todavía — pero aprendí cómo funcionan los servidores, cómo gestionar comunidades y cómo cobrar online siendo menor de edad (con ayuda de mis padres).",
    result: "+3.000€ en ventas",
    color: "var(--primary)"
  },
  {
    title: "Home Lab con Proxmox",
    period: "2024 – presente",
    tags: ["Proxmox", "Kali Linux", "Ubuntu Server", "Virtualización"],
    story: "Reciclé un PC viejo y lo convertí en un servidor doméstico con Proxmox. Corro varias VMs: una con Kali para practicar seguridad, otra con Ubuntu Server para experimentos varios. Lo monté todo solo siguiendo documentación oficial y muchos posts en foros. No soy ningún experto en seguridad, pero me aclaro bien.",
    result: "En uso activo",
    color: "var(--secondary)"
  },
  {
    title: "Este portfolio",
    period: "2025",
    tags: ["Astro", "JavaScript", "CSS", "GitHub Pages"],
    story: "Lo hice mientras aprendía Astro. El diseño es mío. El primer borrador era bastante genérico — claramente generado con IA — así que lo reescribí para que parezca más real. Ahora mismo estás viendo la versión en la que intento que suene como yo y no como un CV de LinkedIn.",
    result: "Lo estás viendo",
    color: "var(--accent)"
  },
];
---

<section id="projects">
  <div class="container">
    <h2>Proyectos</h2>
    <p class="section-sub">Solo pongo los que realmente he hecho. Prefiero tres proyectos reales que veinte de relleno.</p>

    <div class="projects-list">
      {projects.map((project) => (
        <div class="project-card">
          <div class="project-header">
            <div>
              <h3>{project.title}</h3>
              <span class="period">{project.period}</span>
            </div>
            <span class="result" style={`color: ${project.color}; border-color: ${project.color}`}>
              {project.result}
            </span>
          </div>

          <p class="story">{project.story}</p>

          <div class="tags">
            {project.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-sub {
    text-align: center;
    color: var(--text-gray);
    font-size: 1rem;
    margin-top: -2rem;
    margin-bottom: 3rem;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 850px;
    margin: 0 auto;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid rgba(0, 255, 65, 0.1);
    border-radius: 1rem;
    padding: 2rem 2.5rem;
    transition: border-color 0.3s ease;
  }

  .project-card:hover {
    border-color: rgba(0, 255, 65, 0.3);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .project-card h3 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-light);
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 0.25rem;
  }

  .period {
    font-size: 0.85rem;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
  }

  .result {
    font-size: 0.85rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    border: 1px solid;
    padding: 0.35rem 0.85rem;
    border-radius: 50px;
    white-space: nowrap;
  }

  .story {
    color: var(--text-gray);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tag {
    font-size: 0.8rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-dim);
    background: var(--bg-elevated);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.3rem 0.75rem;
    border-radius: 0.35rem;
  }

  @media (max-width: 768px) {
    .project-card {
      padding: 1.5rem;
    }

    .project-header {
      flex-direction: column;
    }
  }
</style>
