    margin-bottom: 1.5rem;
    line-height: 1.85;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  strong {
    color: var(--text-light);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .about-text p {
      font-size: 1rem;
    }
  }
</style>
