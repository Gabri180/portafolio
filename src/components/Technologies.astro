---
const techs = [
  {
    name: "Python",
    desc: "Scripts de automatización, algo de web scraping y experimentos con herramientas de seguridad. Es el lenguaje en el que tengo más soltura."
  },
  {
    name: "Swift / SwiftUI",
    desc: "Llevo más de un año aprendiendo a hacer apps para iOS. He montado algunas apps pequeñas; todavía me cuesta la parte de arquitectura y el manejo de estado complejo."
  },
  {
    name: "JavaScript",
    desc: "Para web, tanto frontend como algo de Node.js. Este portfolio usa Astro con JS. No domino frameworks grandes como Next al 100%, pero me apaño."
  },
  {
    name: "HTML / CSS",
    desc: "Lo básico, y bastante. Sé hacer layouts decentes, animaciones CSS y diseño responsive sin tener que buscar en Stack Overflow cada dos líneas."
  },
  {
    name: "Linux / Bash",
    desc: "Kali en una VM, Ubuntu en el servidor. Me muevo bien por terminal y escribo scripts de bash cuando me hace falta. No uso Windows para casi nada técnico."
  },
  {
    name: "Proxmox",
    desc: "Tengo un servidor en casa con Proxmox corriendo varias VMs. Lo monté solo siguiendo documentación. Si algo falla, lo arreglo yo también."
  },
  {
    name: "Git",
    desc: "Lo uso a diario. Commits, branches, pull requests en GitHub. Nada de workflows complicados de empresa, pero los fundamentos bien asentados."
  },
  {
    name: "Java / C++",
    desc: "Los he tocado en proyectos pequeños. No los elegiría para un proyecto serio todavía, pero me entiendo con ellos cuando hace falta."
  },
  {
    name: "Docker",
    desc: "Lo básico: containers, imágenes, docker-compose para levantar servicios. Me falta profundidad, lo admito."
  },
];
---

<section id="technologies">
  <div class="container">
    <h2>Lo que manejo</h2>
    <p class="section-sub">Sin barras de porcentaje. Esas no significan nada.</p>

    <div class="tech-grid">
      {techs.map((tech) => (
        <div class="tech-item">
          <h3>{tech.name}</h3>
          <p>{tech.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-sub {
    text-align: center;
    color: var(--text-dim);
    font-size: 0.9rem;
    font-family: 'JetBrains Mono', monospace;
    margin-top: -2rem;
    margin-bottom: 3rem;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .tech-item {
    background: var(--bg-card);
    border: 1px solid rgba(0, 255, 65, 0.08);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: border-color 0.3s ease;
  }

  .tech-item:hover {
    border-color: rgba(0, 255, 65, 0.25);
  }

  .tech-item h3 {
    font-size: 1rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    color: var(--primary);
    margin-bottom: 0.6rem;
  }

  .tech-item p {
    font-size: 0.9rem;
    color: var(--text-gray);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 768px) {
    .tech-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
